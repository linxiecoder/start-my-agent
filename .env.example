# Hello Agents 项目环境变量配置示例
# 将此文件复制为 .env 并填写实际的 API 密钥

# ====================
# OpenAI 兼容 API 配置
# ====================

# DeepSeek API (推荐，有免费额度)
API_KEY=your-deepseek-api-key-here
BASE_URL=https://api.deepseek.com
MODEL_ID=deepseek-chat

# 或者使用 OpenAI API
# API_KEY=your-openai-api-key-here
# BASE_URL=https://api.openai.com/v1
# MODEL_ID=gpt-3.5-turbo

# 或者使用本地部署的 OpenAI 兼容服务
# API_KEY=your-local-api-key
# BASE_URL=http://localhost:8080/v1
# MODEL_ID=local-model

# ====================
# 搜索 API 配置
# ====================

# Tavily 搜索 API (用于旅游景点搜索)
TAVILY_API_KEY=your-tavily-api-key-here

# 可选：其他搜索服务
# SERPER_API_KEY=your-serper-api-key
# GOOGLE_API_KEY=your-google-api-key
# GOOGLE_CSE_ID=your-google-cse-id

# ====================
# 本地模型配置
# ====================

# ModelScope 模型缓存路径（可选）
# MODELSCOPE_CACHE_DIR=./models

# 本地模型设备配置
# 可选值: cuda, cpu, mps (Apple Silicon)
# DEVICE=cuda

# 默认本地模型 ID
# LOCAL_MODEL_ID=qwen/Qwen3-0.6B

# ====================
# 项目配置
# ====================

# 日志级别
# LOG_LEVEL=INFO

# 请求超时时间（秒）
# REQUEST_TIMEOUT=30

# 最大重试次数
# MAX_RETRIES=3

# ====================
# 安全配置
# ====================

# 启用 API 密钥加密（可选）
# ENCRYPT_API_KEYS=false

# 敏感数据加密密钥（如果启用加密）
# ENCRYPTION_KEY=your-encryption-key

# ====================
# 开发配置
# ====================

# 启用调试模式
# DEBUG=false

# 启用详细日志
# VERBOSE=false

# 测试模式（使用模拟数据）
# TEST_MODE=false

# ====================
# 注意事項
# ====================

# 1. 不要将此文件提交到版本控制系统
# 2. 实际密钥应保存在安全的 .env 文件中
# 3. 不同环境可使用不同配置文件：
#    - .env.development
#    - .env.production
#    - .env.test

# 使用方法：
# 1. 复制此文件：cp .env.example .env
# 2. 编辑 .env 文件，填写实际 API 密钥
# 3. 确保 .env 在 .gitignore 中